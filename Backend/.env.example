# Environment Variables Template

# MongoDB Connection
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/task_manager?retryWrites=true&w=majority

# JWT Secret for authentication tokens
# Generate a secure random string for production!
JWT_SECRET=your_jwt_secret_here_change_in_production

# Server Port
PORT=4000

# Environment (development or production)
NODE_ENV=development

# Optional: timezone used for streak and reminder day boundaries
# If left as UTC, a 9:00 AM cron will run at 9:00 AM UTC (2:30 PM IST).
# Set to your local timezone (e.g., Asia/Kolkata) to receive emails at your local time.
STREAK_TIMEZONE=UTC
REMINDER_TIMEZONE=Asia/Kolkata

# Optional: cron expression for reminder emails (default: 9:00 AM daily)
REMINDER_CRON=0 9 * * *

# Email (Gmail SMTP example)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM="TaskFlow <your_email@gmail.com>"
