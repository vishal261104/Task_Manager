# Frontend environment variables
# Set this in Vercel/Netlify when deploying.

# Backend origin (Render service URL), e.g.
# VITE_API_ORIGIN=https://your-backend-service.onrender.com
VITE_API_ORIGIN=http://localhost:4000

# Optional: override full API base. Default is ${VITE_API_ORIGIN}/api
# VITE_API_BASE=https://your-backend-service.onrender.com/api
